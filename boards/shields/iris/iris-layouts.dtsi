#include <dt-bindings/zmk/matrix_transform.h>

/ {
    chosen {
        zmk,kscan = &kscan0;
        zmk,matrix-transform = &default_transform;
    };

    default_transform: keymap_transform_0 {
        compatible = "zmk,matrix-transform";
        columns = <6>;
        rows = <5>;
        
        // Map the physical keys to the matrix rows (R) and columns (C)
        map = <
    RC(0,0) RC(0,1) RC(0,2) RC(0,3) RC(0,4) RC(0,5)
    RC(1,0) RC(1,1) RC(1,2) RC(1,3) RC(1,4) RC(1,5)
    RC(2,0) RC(2,1) RC(2,2) RC(2,3) RC(2,4) RC(2,5)
    RC(3,0) RC(3,1) RC(3,2) RC(3,3) RC(3,4) RC(3,5)
    RC(4,0) RC(4,1) RC(4,2) RC(4,3) RC(4,4) RC(4,5)
        >;
    };

    kscan0: kscan {
        compatible = "zmk,kscan-gpio-matrix";
        wakeup-source;

        // Change to "row2col" if your physical diodes point from rows to columns
        diode-direction = "col2row";

        row-gpios
            = <&pro_micro 18 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)> // F4  (Row 0)
            , <&pro_micro 19 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)> // F5  (Row 1)
            , <&pro_micro 20 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)> // F6  (Row 2)
            , <&pro_micro 21 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)> // F7  (Row 3)
            , <&pro_micro 15 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)> // B1  (Row 4)
            ;

        col-gpios
            = <&pro_micro  7 GPIO_ACTIVE_HIGH> // E6  (Col 0 - Leftmost column)
            , <&pro_micro  8 GPIO_ACTIVE_HIGH> // B4  (Col 1)
            , <&pro_micro  9 GPIO_ACTIVE_HIGH> // B5  (Col 2)
            , <&pro_micro 14 GPIO_ACTIVE_HIGH> // B3  (Col 3)
            , <&pro_micro 16 GPIO_ACTIVE_HIGH> // B2  (Col 4)
            , <&pro_micro 10 GPIO_ACTIVE_HIGH> // B6  (Col 5 - Inner column)
            ;
    };
};z