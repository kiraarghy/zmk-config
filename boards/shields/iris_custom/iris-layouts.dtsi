#include <dt-bindings/zmk/matrix_transform.h>

/ {
    chosen {
        zmk,kscan = &kscan0;
        zmk,matrix-transform = &default_transform;
    };

    default_transform: keymap_transform_0 {
        compatible = "zmk,matrix-transform";
        columns = <6>;
        rows = <5>;
        
        // Map the physical keys to the matrix rows (R) and columns (C)
        map = <
    RC(0,0) RC(0,1) RC(0,2) RC(0,3) RC(0,4) RC(0,5)
    RC(1,0) RC(1,1) RC(1,2) RC(1,3) RC(1,4) RC(1,5)
    RC(2,0) RC(2,1) RC(2,2) RC(2,3) RC(2,4) RC(2,5)
    RC(3,0) RC(3,1) RC(3,2) RC(3,3) RC(3,4) RC(3,5)
    RC(4,0) RC(4,1) RC(4,2) RC(4,3) RC(4,4) RC(4,5)
        >;
    };

    kscan0: kscan {
        compatible = "zmk,kscan-gpio-matrix";
        wakeup-source;

        // Change to "row2col" if your physical diodes point from rows to columns
        diode-direction = "col2row";

        row-gpios
            = <&gpio0 17 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)> // Pro Micro 15 (P0.17)
            , <&gpio0 31 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)> // Pro Micro 18 (P0.31)
            , <&gpio0 29 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)> // Pro Micro 19 (P0.29)
            , <&gpio0  2 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)> // Pro Micro 20 (P0.02)
            , <&gpio1 15 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)> // Pro Micro 21 (P1.15)
            ;

        col-gpios
            = <&gpio0 11 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)> // Pro Micro 7 = P0.11
            , <&gpio1  0 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)> // Pro Micro 8 = P1.00
            , <&gpio0 24 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)> // Pro Micro 9 = P0.24
            , <&gpio0  4 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)> // Pro Micro 14 = P0.09
            , <&gpio0 10 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)> // Pro Micro 16 = P0.10
            , <&gpio1  9 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)> // Pro Micro 10 = P1.04
            ;
    };
};